# ── DATABASE ──────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/myna_db"

# ── REDIS (Upstash free tier) ─────────────────────────────
REDIS_URL="redis://localhost:6379"
UPSTASH_REDIS_REST_URL="https://your-upstash-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ── WHATSAPP CLOUD API ────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_ACCESS_TOKEN="your-permanent-access-token"
WHATSAPP_WEBHOOK_VERIFY_TOKEN="your-random-verify-token"
WHATSAPP_BUSINESS_ACCOUNT_ID="your-business-account-id"
WHATSAPP_APP_SECRET="your-meta-app-secret"  # Meta Developer Console → App → Settings → Basic

# ── AI PROVIDERS ─────────────────────────────────────────────────────────────
# PRIMARY (required): OpenRouter free tier — sign up at openrouter.ai
# Model cascade: gemini-2.0-flash-exp:free → llama-3.3-70b:free → qwen2.5-72b:free → mistral-7b:free
OPENROUTER_API_KEY="your-openrouter-api-key"

# OPTIONAL: Groq for Whisper speech-to-text only (groq.com — free tier)
GROQ_API_KEY="your-groq-api-key"

# The following are NOT needed — OpenRouter handles all AI:
# GEMINI_API_KEY, OPENAI_API_KEY, ANTHROPIC_API_KEY

# ── MEDIA APIs ────────────────────────────────────────────
PEXELS_API_KEY="your-pexels-api-key"
PIXABAY_API_KEY="your-pixabay-api-key"

# ── SOCIAL APIS ──────────────────────────────────────────
INSTAGRAM_APP_ID="your-instagram-app-id"
INSTAGRAM_APP_SECRET="your-instagram-app-secret"
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"
TIKTOK_CLIENT_KEY="your-tiktok-client-key"
TIKTOK_CLIENT_SECRET="your-tiktok-client-secret"
YOUTUBE_CLIENT_ID="your-youtube-client-id"
YOUTUBE_CLIENT_SECRET="your-youtube-client-secret"

# ── STORAGE ───────────────────────────────────────────────
STORAGE_TYPE="local"  # local | cloudflare-r2
STORAGE_LOCAL_PATH="./storage"
# Cloudflare R2 (10GB free, zero egress) — recommended for production
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="myna-videos"
R2_PUBLIC_URL="https://your-r2-public-url.r2.dev"

# ── APP ───────────────────────────────────────────────────
NODE_ENV="development"
API_PORT="3001"
API_BASE_URL="https://your-domain.com"
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_WEB_URL="http://localhost:3000"
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"

# ── FFMPEG ────────────────────────────────────────────────
FFMPEG_PATH="/usr/bin/ffmpeg"
FFPROBE_PATH="/usr/bin/ffprobe"
TEMP_DIR="./tmp"
OUTPUT_DIR="./storage/output"
# Optional: path to a bold TTF font for caption burn-in. If omitted, FFmpeg uses its built-in font.
# FFMPEG_FONT_PATH="/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf"

# ── STRIPE (for subscription tiers) ───────────────────────
# Create 2 products in Stripe Dashboard (no prices needed — pricing is dynamic via PPP)
# Each product = one tier. Copy the product ID (prod_...) here.
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_PRODUCT_GROWTH="prod_..."      # Stripe product ID for Growth tier (30/month)
STRIPE_PRODUCT_UNLIMITED="prod_..."   # Stripe product ID for Unlimited tier

# ── ADMIN ─────────────────────────────────────────────────
ADMIN_PASSWORD="change-this-in-production"  # Protects /admin/queues (BullMQ board)
ADMIN_JWT_SECRET="change-this-admin-jwt-secret-min-32-chars"  # Signs admin panel tokens

# ── EMAIL (for admin campaigns) ───────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"   # Gmail: use App Password, not account password
SMTP_FROM="Myna <hello@myna.app>"

# ── ALERTS (Ntfy.sh — free push notifications) ────────────
NTFY_TOPIC="your-ntfy-topic"       # e.g. "myna-prod-alerts" — creates ntfy.sh/your-ntfy-topic
NTFY_URL="https://ntfy.sh"         # Use self-hosted for private alerts
NTFY_TOKEN=""                      # Optional: for private topics (ntfy.sh access token)

# ── PIPER TTS (local voice synthesis) ────────────────────
PIPER_MODEL="/opt/piper/models/en_US-lessac-medium.onnx"  # Download from github.com/rhasspy/piper
